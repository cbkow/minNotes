// Generated by CMake (configure_file) from minNotes.rc.in — DO NOT edit the
// generated build/minNotes.rc; edit this template. Carries the app icon AND a
// VS_VERSION_INFO block so Explorer > Properties > Details and tooling read the
// real version. Version fields are substituted from the CMake project() version.
//
// No "#include <windows.h>": the icon id is a plain resource name and the
// VERSIONINFO flag constants are given as raw numbers, so rc.exe needs no SDK
// headers (matches the original icon-only minNotes.rc). Icon path is absolute
// (forward slashes) because this is configured into the build dir, away from the
// .ico. Strings are ASCII-only to avoid .rc codepage surprises.

IDI_ICON1 ICON "@MN_RC_ICON_PATH@"

// Resource id MUST be the literal 1 (== VS_VERSION_INFO from windows.h, which we
// don't include): Windows only reads version info from resource id 1.
1 VERSIONINFO
 FILEVERSION    @MN_VER_MAJOR@,@MN_VER_MINOR@,@MN_VER_PATCH@,0
 PRODUCTVERSION @MN_VER_MAJOR@,@MN_VER_MINOR@,@MN_VER_PATCH@,0
 FILEFLAGSMASK  0x3fL
 FILEFLAGS      0x0L
 FILEOS         0x40004L
 FILETYPE       0x1L
 FILESUBTYPE    0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "cbkow"
            VALUE "FileDescription",  "minNotes - block-based markdown notes editor"
            VALUE "FileVersion",      "@PROJECT_VERSION@.0"
            VALUE "InternalName",     "minNotes.exe"
            VALUE "LegalCopyright",   "Copyright (C) 2026 cbkow"
            VALUE "OriginalFilename", "minNotes.exe"
            VALUE "ProductName",      "minNotes"
            VALUE "ProductVersion",   "@PROJECT_VERSION@.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
