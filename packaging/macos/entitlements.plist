<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened runtime entitlements for Developer ID / DMG distribution. -->

    <!-- Allow loading the vendored FFmpeg dylibs (JIT-style codegen). -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allow loading dylibs/frameworks from @rpath (Contents/Frameworks). -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Network access: Sparkle update checks + remote <img> download on paste. -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Read/write user-selected files (open/save documents + imported media). -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
</dict>
</plist>
