# Build output
/build/

# clangd / IDE index caches
.cache/
compile_commands.json

# macOS / editor cruft
.DS_Store
*.user
*.swp

# Spike harness build dir (throwaway; sources kept for reference)
/spike/build/

# KSyntaxHighlighting built from source (run external/build-ksyntax.sh)
/external/kf6/
/external/src/
# Vendored prebuilt FFmpeg for the video engine (app/player/) — per-platform
# binaries (macOS dylibs / Windows lib+dll), not built from this tree.
/external/ffmpeg/

# Aspekta font upstream package (only the used .ttf are vendored in app/.../fonts/)
/external/aspekta/

# Vendored Sparkle.framework + tools (macOS auto-update). Copied from QCView /
# fetched from the Sparkle GitHub release; not committed (binary framework).
# The CMake bundle block guards on its presence, so the build works without it.
/external/Sparkle/

# Icon Composer upstream drops (the layered .icon + source SVGs). The committed
# render is packaging/macos/minNotesMacOS.png; the .icon is needed only to
# regenerate Assets.car on macOS 26 builds.
/external/icons/

# Sparkle EdDSA PRIVATE key. `generate_keys -x` exports it to a plaintext file —
# it must NEVER be committed (the private key signs every future auto-update).
# It belongs in the login Keychain + an out-of-repo backup. The PUBLIC key is in
# packaging/macos/Info.plist.in, which is fine to commit.
sparkle_private_key*.txt

# Release artifacts dragged to the repo root (the canonical ones live in build/,
# already ignored above — this is a safety net for stray copies before upload).
/*.dmg
/*.zip
